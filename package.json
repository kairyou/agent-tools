{
  "name": "@kairyou/agent-tools",
  "version": "0.7.0",
  "description": "Reusable Agent Skills and installable integrations (statusline, provider usage, vision) for Codex, Claude Code, and opencode.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "config.default.jsonc",
    "dist/",
    "integrations/",
    "scripts/",
    "skills/"
  ],
  "dependencies": {
    "jsonc-parser": "3.3.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "esbuild": "0.28.1",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "test": "node --test tests/*.test.mjs",
    "release": "node scripts/release.mjs"
  },
  "bin": {
    "agent-tools": "./scripts/install.mjs"
  }
}
